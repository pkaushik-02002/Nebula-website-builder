rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function computerPath(computerId) {
      return /databases/$(database)/documents/computers/$(computerId);
    }

    function computerData(computerId) {
      return get(computerPath(computerId)).data;
    }

    function isComputerOwner(data) {
      return signedIn() && request.auth.uid == data.ownerId;
    }

    function isComputerCollaborator(data) {
      return signedIn()
        && data.collaboratorIds is list
        && request.auth.uid in data.collaboratorIds;
    }

    function canReadComputer(data) {
      return isComputerOwner(data) || isComputerCollaborator(data);
    }

    match /computers/{id} {
      allow read: if canReadComputer(resource.data);
      allow create: if signedIn() && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if isComputerOwner(resource.data);

      match /versions/{versionId} {
        allow read: if canReadComputer(computerData(id));
        allow write: if false;
      }
    }

    match /computerInvites/{inviteId} {
      allow read, write: if false;
    }
  }
}
