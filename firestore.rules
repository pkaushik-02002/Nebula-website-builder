rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /computers/{id} {
      allow read: if request.auth.uid == resource.data.ownerId
        || (
          resource.data.collaboratorIds is list
          && request.auth.uid in resource.data.collaboratorIds
        );
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth.uid == resource.data.ownerId;

      match /versions/{versionId} {
        allow read: if request.auth.uid == get(/databases/$(database)/documents/computers/$(id)).data.ownerId
          || (
            get(/databases/$(database)/documents/computers/$(id)).data.collaboratorIds is list
            && request.auth.uid in get(/databases/$(database)/documents/computers/$(id)).data.collaboratorIds
          );
        allow write: if false;
      }
    }
  }
}
