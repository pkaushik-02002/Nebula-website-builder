# App URL (used for OAuth callbacks and Stripe success/cancel URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server; used for auth and Firestore, e.g. Stripe webhook updates)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# OpenAI (generate API)
OPENAI_API_KEY=

# Stripe (subscriptions – pricing page and checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Connect (optional): 50/50 revenue share – friend's connected account ID (acct_xxx)
FRIEND_STRIPE_ACCOUNT_ID=
# Optional: fallback price IDs when Stripe API is not used to list prices
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=

# E2B (sandbox)
E2B_API_KEY=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
GITHUB_WEBHOOK_SECRET=

# Netlify OAuth
NETLIFY_CLIENT_ID=
NETLIFY_CLIENT_SECRET=
NETLIFY_REDIRECT_URI=

# Vercel: no env vars needed — user provides Personal Access Token per project

# Optional: env encryption, seed plans
ENV_ENCRYPTION_KEY=
SEED_PLANS_SECRET=
